APP_NAME=AI Education Platform API
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-secret
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=120

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_education
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

CHROMA_PERSIST_DIR=./storage/chroma
MATERIAL_STORAGE_DIR=./storage/materials

FEATURE_PERSONALIZED_PATHS=true
FEATURE_DIFFICULTY_ADAPTATION=true
FEATURE_KNOWLEDGE_GRAPH=true
