# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AI Education Platform API
APP_ENV=production
APP_DEBUG=false
# Comma-separated Vercel domain(s)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>
SUPABASE_STORAGE_BUCKET=course-materials

# ── PostgreSQL (Supabase pooler for production) ───────────────────────────────
DATABASE_URL_OVERRIDE=postgresql://postgres.<project-ref>:<db-password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=<qdrant-api-key>
QDRANT_COLLECTION=course_materials

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=<groq-api-key>
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_QUALITY_MODEL=llama-3.3-70b-versatile

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<openai-api-key>
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Features ─────────────────────────────────────────────────────────────────
FEATURE_PERSONALIZED_PATHS=true
FEATURE_DIFFICULTY_ADAPTATION=true
FEATURE_KNOWLEDGE_GRAPH=true
